APP_HOST=0.0.0.0
APP_PORT=8080
FRONTEND_URL=http://localhost:5173

# Database backend: "postgres" (default) or "rustdb"
DB_BACKEND=postgres

# PostgreSQL example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/household_dashboard
# Rust-DB example (via pgwire):
# DATABASE_URL=postgresql://admin:secret@127.0.0.1:5433/household_dashboard

REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800
TOTP_ISSUER=HouseholdDashboard
DEVICE_TRUST_TTL_SECONDS=2592000

# Optional: auto-create a superadmin account on startup
# SUPERADMIN_EMAIL=admin@example.com
# SUPERADMIN_PASSWORD=changeme123456

VITE_API_BASE_URL=/api
VITE_WS_PATH=/ws
