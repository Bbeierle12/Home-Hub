{
  "name": "household-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "check:frontend": "npm --prefix frontend run check",
    "check:backend": "cargo check --manifest-path backend/Cargo.toml",
    "check": "npm run check:frontend && npm run check:backend"
  },
  "workspaces": ["frontend"]
}
